{
  "name": "json-txt-visualizer",
  "displayName": "JSON TXT Visualizer",
  "description": "Visualize large .txt files containing concatenated JSON objects in a high-performance data table",
  "version": "0.1.0",
  "publisher": "json-txt-visualizer",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jsonTxtVisualizer.openViewer",
        "title": "JSON TXT Visualizer: Open Viewer"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build && npm run build:webview",
    "build": "tsc -p tsconfig.json",
    "build:webview": "cd webview-ui && npm run build",
    "watch": "tsc -watch -p tsconfig.json",
    "install:all": "npm install && cd webview-ui && npm install",
    "test": "node out/test/runTests.js",
    "test:parser": "npx ts-mocha src/test/parser.test.ts --timeout 10000"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@types/mocha": "^10.0.6",
    "mocha": "^10.3.0",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {}
}
